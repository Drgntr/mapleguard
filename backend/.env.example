# =============================================================================
# MapleGuard Backend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# =============================================================================

# ── MSU / Nexpace API ────────────────────────────────────────────────────
MSU_OPENAPI_KEY=

# ── Redis (optional — app falls back to in-memory cache) ─────────────────
# REDIS_URL=redis://localhost:6379/0

# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./mapleguard.db

# ── Proxies ──────────────────────────────────────────────────────────────
# Option 1: Path to Webshare proxy file (auto-detected if in project root)
# PROXY_FILE_PATH=C:\Scripts\Maple\MapleGuard\Webshare 100 proxies.txt

# Option 2: Comma-separated proxy URLs
# PROXY_LIST=http://user:pass@ip:port,http://user:pass@ip2:port2

# ── Frontend URL (for CORS) ──────────────────────────────────────────────
# FRONTEND_URL=http://localhost:3000
